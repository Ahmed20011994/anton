PORT=8080
APP_ENV=development
LOG_LEVEL=info
WORKER_COUNT=4

# Postgres (matches docker-compose)
POSTGRES_PASSWORD=anton
DATABASE_URL=postgres://anton:anton@localhost:5432/anton?sslmode=disable

# 32-byte key, base64-encoded. Generate one with:
#   openssl rand -base64 32
# Do NOT commit your real key to git.
ENCRYPTION_KEY=replace-me-with-base64-32-bytes
